{
  "name": "servicescope",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run test:calendar-technician && npm run test:calendar-persistence && npm run test:warehouse-adjustments && tsc -b && vite build",
    "test:warehouse-import": "node scripts/warehouse-import-regression-tests.mjs",
    "test:warehouse-categories": "node scripts/warehouse-categories-regression-tests.mjs",
    "test:warehouse-daily": "node scripts/warehouse-daily-workflows-regression-tests.mjs",
    "test:warehouse-job-materials": "node scripts/warehouse-job-materials-regression-tests.mjs",
    "test:warehouse-adjustments": "node scripts/warehouse-adjustments-regression-tests.mjs",
    "test:calendar-technician": "node scripts/calendar-technician-selection-regression-tests.mjs",
    "test:calendar-persistence": "node scripts/calendar-persistence-regression-tests.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "tech:install": "npm install --prefix apps/technician-mobile/client",
    "tech:dev": "npm start --prefix apps/technician-mobile/client",
    "tech:build": "npm run build --prefix apps/technician-mobile/client"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
